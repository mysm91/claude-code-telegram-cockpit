{
  "name": "claude-code-telegram-cockpit",
  "version": "0.1.0",
  "description": "Drive Claude Code from Telegram — sessions, permissions, plans, usage, and away-mode. Runs locally on your own machine (session content transits Telegram, so it is not end-to-end encrypted).",
  "type": "module",
  "license": "MIT",
  "author": "Meysam Shahrashoub (https://github.com/mysm91)",
  "repository": { "type": "git", "url": "https://github.com/mysm91/claude-code-telegram-cockpit.git" },
  "homepage": "https://github.com/mysm91/claude-code-telegram-cockpit#readme",
  "bugs": "https://github.com/mysm91/claude-code-telegram-cockpit/issues",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsc && node dist/main.js",
    "test": "tsc && node --test \"test/*.test.mjs\""
  },
  "keywords": [
    "claude-code",
    "telegram",
    "telegram-bot",
    "remote-control",
    "agent-sdk",
    "cli"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "grammy": "^1.44.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
